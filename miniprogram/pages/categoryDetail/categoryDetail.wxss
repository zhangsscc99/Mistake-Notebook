/* pages/categoryDetail/categoryDetail.wxss */
.header {
  padding: 16px 20px;
  color: #ffffff;
}

.header-title {
  font-size: 20px;
  font-weight: bold;
}

.header-subtitle {
  font-size: 13px;
  margin-top: 4px;
  opacity: 0.9;
}

.question-list {
  padding-bottom: 24px;
}

.question-card {
  padding: 16px;
  margin-top: 12px;
}

.question-header {
  border-bottom: 1px solid #f2f3f5;
  padding-bottom: 10px;
  margin-bottom: 12px;
}

.badge-container {
  display: flex;
  flex-wrap: wrap;
}

.badge {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 4px;
  font-weight: bold;
  margin-right: 6px;
}

.badge-easy {
  background-color: #e8f5e9;
  color: #4caf50;
}

.badge-medium {
  background-color: #fff3e0;
  color: #ff9800;
}

.badge-hard {
  background-color: #ffebee;
  color: #f44336;
}

.tag-badge {
  font-size: 11px;
  padding: 2px 6px;
  border-radius: 4px;
  background-color: #f2f3f5;
  color: #646566;
  margin-right: 6px;
}

.question-date {
  font-size: 11px;
  color: #969799;
}

.question-body {
  margin-bottom: 12px;
}

.question-text {
  font-size: 15px;
  color: #323233;
  line-height: 1.5;
  white-space: pre-wrap;
  word-break: break-all;
}

.question-img {
  width: 100%;
  height: 160px;
  border-radius: 4px;
  margin-bottom: 12px;
  background-color: #f7f8fa;
}

.ai-box {
  background-color: #f7f8fa;
  padding: 12px;
  border-radius: 6px;
  margin-bottom: 12px;
  border-left: 3px solid #1989fa;
}

.ai-title {
  font-size: 13px;
  font-weight: bold;
  margin-bottom: 8px;
}

.ai-subtitle {
  font-size: 12px;
  font-weight: bold;
  color: #323233;
  margin-top: 6px;
}

.ai-content {
  font-size: 12px;
  color: #646566;
  line-height: 1.5;
  white-space: pre-wrap;
  word-break: break-all;
}

.question-actions {
  border-top: 1px solid #f2f3f5;
  padding-top: 10px;
  margin-top: 12px;
}

.btn-sm {
  font-size: 12px !important;
  padding: 6px 12px !important;
  border-radius: 12px !important;
}

.delete-btn {
  color: #ee0a24 !important;
  background-color: #fff0f0 !important;
  border: none !important;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 20px;
}

.empty-text {
  font-size: 16px;
  font-weight: bold;
  color: #323233;
}

.empty-desc {
  font-size: 13px;
  color: #969799;
  margin-top: 6px;
}

.go-back-btn {
  margin-top: 24px;
  width: 140px;
  border-radius: 20px;
}