/* pages/categoryDetail/categoryDetail.wxss */
.category-detail-page {
  min-height: 100vh;
  padding-bottom: 120px;
  position: relative;
  background: #eaf3ff;
}

.edit-toolbar {
  display: flex;
  justify-content: flex-end;
  gap: 16px;
  padding: 0 16px 8px;
}

.edit-action {
  font-size: 14px;
  font-weight: 600;
  color: #2459ff;
  padding: 6px 4px;
}

/* 分类信息卡片（精确复刻 Web 端） */
.info-section {
  padding: 16px;
}

.category-info-card {
  position: relative;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(47, 107, 255, 0.14);
  border-radius: 20px;
  padding: 24px;
  box-shadow:
    0 20px 70px rgba(31, 91, 255, 0.06),
    0 14px 44px rgba(11, 22, 51, 0.06),
    inset 0 1px 0 rgba(255, 255, 255, 0.55);
  overflow: hidden;
}

.category-info-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, #2459ff 0%, #52b7ff 50%, #b6a6ff 100%);
  border-radius: 20px 20px 0 0;
}

.info-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20px;
}

.category-icon-wrap {
  width: 52px;
  height: 52px;
  border-radius: 12px;
  background: rgba(36, 89, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16px;
  flex-shrink: 0;
}

.category-icon-text {
  font-size: 20px;
  font-weight: bold;
  color: #2459ff;
}

.info-details {
  flex: 1;
}

.category-name {
  font-size: 20px;
  font-weight: 800;
  color: #0b1633;
  margin-bottom: 4px;
}

.category-desc-text {
  font-size: 14px;
  color: rgba(11, 22, 51, 0.62);
  margin-bottom: 8px;
}

.category-stats-row {
  display: flex;
  gap: 8px;
}

.stat-pill {
  font-size: 12px;
  color: rgba(11, 22, 51, 0.62);
  padding: 3px 10px;
  background: rgba(11, 22, 51, 0.05);
  border-radius: 12px;
}

.action-buttons-row {
  display: flex;
  gap: 10px;
}

.action-btn {
  flex: 1;
  height: 36px !important;
  font-size: 13px !important;
  line-height: 36px !important;
  border-radius: 10px !important;
}

/* 筛选栏 */
.filter-section {
  padding: 0 16px 16px 16px;
}

.filter-scroll {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  white-space: nowrap;
  padding: 8px 0;
}

.filter-chip {
  display: inline-block;
  padding: 6px 14px;
  font-size: 13px;
  border-radius: 20px;
  background: rgba(255, 255, 255, 0.6);
  color: rgba(11, 22, 51, 0.62);
  border: 1px solid rgba(47, 107, 255, 0.10);
  transition: all 0.2s;
}

.filter-chip.active {
  background: rgba(36, 89, 255, 0.10);
  color: #2459ff;
  border-color: rgba(36, 89, 255, 0.25);
  font-weight: 600;
}

/* 题目列表 */
.questions-section {
  padding: 0 16px 24px 16px;
}

.question-card {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  position: relative;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(47, 107, 255, 0.14);
  border-radius: 16px;
  padding: 20px 16px;
  margin-bottom: 16px;
  box-shadow:
    0 20px 70px rgba(31, 91, 255, 0.06),
    0 14px 44px rgba(11, 22, 51, 0.06),
    inset 0 1px 0 rgba(255, 255, 255, 0.55);
  overflow: hidden;
}

.question-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4px;
  height: 100%;
  background: linear-gradient(180deg, #2459ff, #52b7ff);
  border-radius: 16px 0 0 16px;
  box-shadow: 0 0 8px rgba(31, 91, 255, 0.35);
}

.question-card.selected {
  border-color: rgba(36, 89, 255, 0.35);
  box-shadow: 0 0 0 1px rgba(36, 89, 255, 0.12);
}

.question-select-wrap {
  padding-top: 2px;
  flex-shrink: 0;
}

.question-card-body {
  flex: 1;
  min-width: 0;
}

.question-img {
  width: 100%;
  max-height: 200px;
  border-radius: 10px;
  margin-bottom: 12px;
  background: rgba(11, 22, 51, 0.03);
}

.question-text-wrap {
  margin-bottom: 10px;
}

.question-text {
  font-size: 14px;
  color: #0b1633;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-all;
}

.question-tags {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  margin-bottom: 12px;
}

.custom-tag {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 6px;
  background: rgba(36, 89, 255, 0.08);
  color: #2459ff;
  border: 1px solid rgba(36, 89, 255, 0.12);
}

.question-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid rgba(11, 22, 51, 0.08);
  padding-top: 12px;
}

.meta-left {
  display: flex;
  align-items: center;
  gap: 8px;
}

.meta-right {
  display: flex;
  align-items: center;
  gap: 8px;
}

.badge {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 6px;
  font-weight: bold;
}

.badge-easy {
  background: rgba(76, 175, 80, 0.10);
  color: #4caf50;
  border: 1px solid rgba(76, 175, 80, 0.20);
}

.badge-medium {
  background: rgba(255, 152, 0, 0.10);
  color: #ff9800;
  border: 1px solid rgba(255, 152, 0, 0.20);
}

.badge-hard {
  background: rgba(244, 67, 54, 0.10);
  color: #f44336;
  border: 1px solid rgba(244, 67, 54, 0.20);
}

.add-time {
  font-size: 12px;
  color: rgba(11, 22, 51, 0.50);
}

.ai-toggle-btn {
  font-size: 12px !important;
  padding: 4px 12px !important;
  height: 28px !important;
  line-height: 28px !important;
  border-radius: 8px !important;
  background: rgba(36, 89, 255, 0.08) !important;
  color: #2459ff !important;
  border: 1px solid rgba(36, 89, 255, 0.15) !important;
}

.ai-toggle-btn::after {
  border: none !important;
}

.ai-toggle-btn.active {
  background: rgba(36, 89, 255, 0.15) !important;
}

.delete-btn {
  font-size: 12px !important;
  padding: 4px 12px !important;
  height: 28px !important;
  line-height: 28px !important;
  border-radius: 8px !important;
  color: #ff4d4f !important;
  background: rgba(255, 77, 79, 0.08) !important;
  border: 1px solid rgba(255, 77, 79, 0.15) !important;
}

.delete-btn::after {
  border: none !important;
}

.ai-box {
  background: linear-gradient(135deg, rgba(31, 91, 255, 0.04), rgba(82, 183, 255, 0.02));
  border: 1px solid rgba(31, 91, 255, 0.12);
  border-left: 4px solid #2459ff;
  padding: 14px 12px;
  border-radius: 10px;
  margin-top: 14px;
}

.ai-title {
  font-size: 14px;
  font-weight: bold;
  margin-bottom: 10px;
  color: #2459ff;
}

.ai-subtitle {
  font-size: 12px;
  font-weight: bold;
  color: #0b1633;
  margin-top: 8px;
}

.ai-content {
  font-size: 13px;
  color: rgba(11, 22, 51, 0.62);
  line-height: 1.5;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 20px;
  text-align: center;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 16px;
  font-weight: bold;
  color: #0b1633;
  margin-bottom: 24px;
}

.go-back-btn {
  width: 140px !important;
  border-radius: 20px !important;
}

.ai-subtitle-gap {
  margin-top: 10px;
}

.batch-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 12px 16px calc(12px + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(16px);
  border-top: 1px solid rgba(47, 107, 255, 0.14);
  box-shadow: 0 -8px 24px rgba(11, 22, 51, 0.08);
  z-index: 100;
}

.batch-info {
  font-size: 14px;
  font-weight: 600;
  color: #0b1633;
  flex-shrink: 0;
}

.batch-buttons {
  display: flex;
  gap: 8px;
}

.batch-btn {
  margin: 0 !important;
  border-radius: 12px !important;
}

.btn-danger {
  background: #ff4d4f !important;
  color: #fff !important;
}

/* 知识点分组 */
.knowledge-points-section {
  padding: 0 16px;
  margin-bottom: 12px;
}

.knowledge-group {
  margin-bottom: 12px;
  border-radius: 16px;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 4px 16px rgba(11, 22, 51, 0.05);
}

.group-header {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid rgba(11, 22, 51, 0.06);
  cursor: pointer;
}

.group-arrow {
  font-size: 16px;
  color: #2459ff;
  margin-right: 8px;
  width: 16px;
}

.group-title {
  flex: 1;
  font-size: 15px;
  font-weight: 600;
  color: #0b1633;
}

.group-count {
  font-size: 13px;
  color: rgba(11, 22, 51, 0.45);
  background: rgba(36, 89, 255, 0.08);
  padding: 2px 10px;
  border-radius: 999px;
}

.group-questions {
  padding: 8px;
}

.group-questions .question-card {
  margin-bottom: 8px;
  border-radius: 12px;
  box-shadow: none;
  border: 1px solid rgba(11, 22, 51, 0.06);
}

/* 分组切换按钮 */
.group-toggle-btn {
  color: rgba(11, 22, 51, 0.5) !important;
  font-weight: 500 !important;
}

/* 题目详情弹窗 */
.detail-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 200;
}

.detail-modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 88%;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 16px;
  z-index: 201;
  overflow: hidden;
}

.detail-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 18px;
  border-bottom: 1px solid rgba(11, 22, 51, 0.08);
}

.detail-modal-title {
  font-size: 16px;
  font-weight: 600;
  color: #0b1633;
}

.detail-modal-close {
  font-size: 26px;
  line-height: 1;
  color: #aaa;
}

.detail-modal-body {
  flex: 1;
  padding: 16px 18px;
}

.detail-img {
  width: 100%;
  border-radius: 10px;
  margin-bottom: 14px;
}

.detail-section {
  margin-bottom: 16px;
}

.detail-section-title {
  display: block;
  font-size: 13px;
  font-weight: 600;
  color: #2459ff;
  margin-bottom: 6px;
}

.detail-section-body {
  display: block;
  font-size: 14px;
  line-height: 1.7;
  color: #0b1633;
  white-space: pre-wrap;
  word-break: break-word;
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.detail-modal-confirm {
  margin: 0 18px 18px;
  background: #2459ff;
  color: #fff;
  border-radius: 999px;
  font-size: 15px;
}
