/* pages/categoryDetail/categoryDetail.wxss */
.category-detail-page {
  min-height: 100vh;
  padding-bottom: 120px;
  position: relative;
  /* 学术纸张氛围：极淡的网格 + 顶部品牌光晕 */
  background-color: #eef3fb;
  background-image:
    radial-gradient(circle 420rpx at 100% 0%, rgba(82, 183, 255, 0.12) 0%, transparent 60%),
    radial-gradient(circle 360rpx at 0% 4%, rgba(182, 166, 255, 0.10) 0%, transparent 55%),
    linear-gradient(rgba(11, 22, 51, 0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(11, 22, 51, 0.025) 1px, transparent 1px);
  background-size: auto, auto, 44rpx 44rpx, 44rpx 44rpx;
}

.edit-toolbar {
  display: flex;
  justify-content: flex-end;
  gap: 16px;
  padding: 0 16px 8px;
}

.edit-action {
  font-size: 14px;
  font-weight: 600;
  color: #2459ff;
  padding: 6px 4px;
}

/* 分类信息卡片（精确复刻 Web 端） */
.info-section {
  padding: 16px;
}

.category-info-card {
  position: relative;
  background: #ffffff;
  border: 1px solid rgba(11, 22, 51, 0.06);
  border-radius: 22px;
  padding: 26px 22px 22px;
  box-shadow:
    0 18px 50px rgba(31, 91, 255, 0.10),
    0 2px 0 rgba(255, 255, 255, 0.9) inset;
  overflow: hidden;
}

.category-info-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, #2459ff 0%, #52b7ff 50%, #b6a6ff 100%);
  border-radius: 22px 22px 0 0;
}

.info-header {
  display: flex;
  align-items: center;
  margin-bottom: 18px;
}

.category-icon-wrap {
  width: 56px;
  height: 56px;
  border-radius: 16px;
  background: linear-gradient(140deg, #2459ff 0%, #52b7ff 55%, #b6a6ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16px;
  flex-shrink: 0;
  box-shadow: 0 8px 20px rgba(31, 91, 255, 0.30);
}

.category-icon-text {
  font-size: 24px;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: -1px;
}

.info-details {
  flex: 1;
  min-width: 0;
}

.category-name {
  font-size: 23px;
  font-weight: 800;
  color: #0b1633;
  letter-spacing: -0.5px;
  margin-bottom: 3px;
}

.category-desc-text {
  font-size: 13px;
  color: rgba(11, 22, 51, 0.50);
  margin-bottom: 10px;
}

.category-stats-row {
  display: flex;
  gap: 8px;
}

.stat-pill {
  font-size: 12px;
  font-weight: 600;
  color: rgba(11, 22, 51, 0.60);
  padding: 4px 11px;
  background: rgba(11, 22, 51, 0.045);
  border-radius: 8px;
}

.action-buttons-row {
  display: flex;
  gap: 10px;
}

.action-btn {
  flex: 1;
  height: 44px !important;
  font-size: 15px !important;
  font-weight: 700 !important;
  line-height: 44px !important;
  border-radius: 14px !important;
  letter-spacing: 1px !important;
}

.action-btn::after {
  border: none !important;
}

/* 两个操作按钮统一：实心品牌渐变，仅亮度略作区分 */
.action-buttons-row .btn-primary {
  background: linear-gradient(135deg, #2459ff 0%, #52b7ff 100%) !important;
  color: #ffffff !important;
  border: none !important;
  box-shadow: 0 10px 24px rgba(31, 91, 255, 0.32) !important;
}

.action-buttons-row .btn-secondary {
  background: linear-gradient(135deg, #4b7aff 0%, #7dcbff 100%) !important;
  color: #ffffff !important;
  border: none !important;
  box-shadow: 0 10px 24px rgba(31, 91, 255, 0.20) !important;
  backdrop-filter: none !important;
  -webkit-backdrop-filter: none !important;
}

/* 筛选栏 */
.filter-section {
  padding: 0 16px 16px 16px;
}

.filter-scroll {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  white-space: nowrap;
  padding: 8px 0;
}

.filter-chip {
  display: inline-block;
  padding: 7px 15px;
  font-size: 13px;
  font-weight: 600;
  border-radius: 10px;
  background: #ffffff;
  color: rgba(11, 22, 51, 0.55);
  border: 1px solid rgba(11, 22, 51, 0.08);
  transition: all 0.2s;
}

.filter-chip.active {
  background: linear-gradient(135deg, #2459ff, #52b7ff);
  color: #ffffff;
  border-color: transparent;
  font-weight: 700;
  box-shadow: 0 6px 16px rgba(31, 91, 255, 0.28);
}

/* 题目列表 */
.questions-section {
  padding: 0 16px 24px 16px;
}

.question-card {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  position: relative;
  background: #ffffff;
  border: 1px solid rgba(11, 22, 51, 0.06);
  border-radius: 18px;
  padding: 22px 16px 16px;
  margin-bottom: 18px;
  box-shadow:
    0 12px 36px rgba(11, 22, 51, 0.06),
    0 2px 0 rgba(255, 255, 255, 0.9) inset;
  overflow: visible;
}

.question-card.selected {
  border-color: rgba(36, 89, 255, 0.45);
  box-shadow:
    0 0 0 2px rgba(36, 89, 255, 0.18),
    0 12px 36px rgba(31, 91, 255, 0.12);
}

.select-box {
  width: 22px;
  height: 22px;
  border-radius: 6px;
  border: 2px solid rgba(36, 89, 255, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  box-sizing: border-box;
}

.select-box.checked {
  background: #2459ff;
  border-color: #2459ff;
}

.select-check {
  color: #fff;
  font-size: 14px;
  font-weight: 700;
  line-height: 1;
}

.question-card-body {
  flex: 1;
  min-width: 0;
}

/* 题目原图：固定高度的精致框，不再撑出大白块 */
.question-img-frame {
  position: relative;
  width: 100%;
  height: 300rpx;
  border-radius: 14rpx;
  overflow: hidden;
  margin-bottom: 14px;
  border: 1px solid rgba(11, 22, 51, 0.08);
  background: linear-gradient(135deg, rgba(36,89,255,0.05), rgba(182,166,255,0.04));
}

.question-img {
  width: 100%;
  height: 100%;
  display: block;
}

.img-zoom-pill {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  font-size: 11px;
  color: #ffffff;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(11, 22, 51, 0.55);
  backdrop-filter: blur(4px);
}

/* 试卷式题号标记 */
.q-index-tag {
  position: absolute;
  top: -10rpx;
  left: -10rpx;
  min-width: 44rpx;
  height: 44rpx;
  padding: 0 8rpx;
  border-radius: 12rpx 4rpx 12rpx 4rpx;
  background: linear-gradient(140deg, #2459ff, #52b7ff);
  color: #ffffff;
  font-size: 13px;
  font-weight: 800;
  line-height: 44rpx;
  text-align: center;
  box-shadow: 0 6rpx 14rpx rgba(31, 91, 255, 0.32);
  z-index: 3;
}

.question-text-wrap {
  margin-bottom: 10px;
}

.question-text {
  font-size: 15px;
  color: #1a2440;
  line-height: 1.7;
  letter-spacing: 0.2px;
  white-space: pre-wrap;
  word-break: break-word;
}

.question-tags {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  margin-bottom: 12px;
}

.custom-tag {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 6px;
  background: rgba(36, 89, 255, 0.08);
  color: #2459ff;
  border: 1px solid rgba(36, 89, 255, 0.12);
}

.question-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid rgba(11, 22, 51, 0.06);
  padding-top: 12px;
}

.meta-left {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
}

.meta-right {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}

.badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  font-size: 12px;
  padding: 5rpx 22rpx 5rpx 16rpx;
  border-radius: 999px;
  font-weight: 700;
  letter-spacing: 0.5px;
  white-space: nowrap;
  flex-shrink: 0;
  border: none;
}

.badge::before {
  content: '';
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: currentColor;
  flex-shrink: 0;
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.6);
}

.badge-easy {
  color: #15a34a;
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.16), rgba(34, 197, 94, 0.08));
}

.badge-medium {
  color: #c2680a;
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.18), rgba(245, 158, 11, 0.08));
}

.badge-hard {
  color: #e11d48;
  background: linear-gradient(135deg, rgba(244, 63, 94, 0.18), rgba(244, 63, 94, 0.08));
}

.add-time {
  font-size: 12px;
  color: rgba(11, 22, 51, 0.45);
  white-space: nowrap;
}

/* AI 解析：整行主操作按钮 */
.ai-toggle-btn {
  display: block !important;
  width: 100% !important;
  margin-top: 12px !important;
  font-size: 14px !important;
  font-weight: 700 !important;
  letter-spacing: 1px !important;
  padding: 0 !important;
  height: 40px !important;
  line-height: 40px !important;
  border-radius: 12px !important;
  background: linear-gradient(135deg, #2459ff 0%, #52b7ff 100%) !important;
  color: #ffffff !important;
  border: none !important;
  box-shadow: 0 8px 20px rgba(31, 91, 255, 0.26) !important;
}

.ai-toggle-btn::after {
  border: none !important;
}

.ai-toggle-btn.active {
  background: #ffffff !important;
  color: #2459ff !important;
  border: 1px solid rgba(36, 89, 255, 0.30) !important;
  box-shadow: none !important;
}


.ai-box {
  background: linear-gradient(135deg, rgba(31, 91, 255, 0.04), rgba(82, 183, 255, 0.02));
  border: 1px solid rgba(31, 91, 255, 0.12);
  border-left: 4px solid #2459ff;
  padding: 14px 12px;
  border-radius: 10px;
  margin-top: 14px;
}

.ai-title {
  font-size: 14px;
  font-weight: bold;
  margin-bottom: 10px;
  color: #2459ff;
}

.ai-subtitle {
  font-size: 12px;
  font-weight: bold;
  color: #0b1633;
  margin-top: 8px;
}

.ai-content {
  font-size: 13px;
  color: rgba(11, 22, 51, 0.62);
  line-height: 1.5;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 20px;
  text-align: center;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 16px;
  font-weight: bold;
  color: #0b1633;
  margin-bottom: 24px;
}

.go-back-btn {
  width: 140px !important;
  border-radius: 20px !important;
}

.ai-subtitle-gap {
  margin-top: 10px;
}

.batch-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 12px 16px calc(12px + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(16px);
  border-top: 1px solid rgba(47, 107, 255, 0.14);
  box-shadow: 0 -8px 24px rgba(11, 22, 51, 0.08);
  z-index: 100;
}

.batch-info {
  font-size: 14px;
  font-weight: 600;
  color: #0b1633;
  flex-shrink: 0;
}

.batch-buttons {
  display: flex;
  gap: 8px;
}

.batch-btn {
  margin: 0 !important;
  border-radius: 12px !important;
}

.btn-danger {
  background: #ff4d4f !important;
  color: #fff !important;
}

/* 知识点分组 */
.knowledge-points-section {
  padding: 0 16px;
  margin-bottom: 12px;
}

.knowledge-group {
  margin-bottom: 12px;
  border-radius: 16px;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 4px 16px rgba(11, 22, 51, 0.05);
}

.group-header {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid rgba(11, 22, 51, 0.06);
  cursor: pointer;
}

.group-arrow {
  font-size: 16px;
  color: #2459ff;
  margin-right: 8px;
  width: 16px;
}

.group-title {
  flex: 1;
  font-size: 15px;
  font-weight: 700;
  color: #0b1633;
  letter-spacing: -0.2px;
}

.group-count {
  font-size: 12px;
  font-weight: 600;
  color: #2459ff;
  background: rgba(36, 89, 255, 0.10);
  padding: 3px 11px;
  border-radius: 999px;
}

.group-questions {
  padding: 8px;
}

.group-questions .question-card {
  margin-bottom: 8px;
  border-radius: 12px;
  box-shadow: none;
  border: 1px solid rgba(11, 22, 51, 0.06);
}

/* 题目详情弹窗 */
.detail-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 200;
}

.detail-modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 88%;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 16px;
  z-index: 201;
  overflow: hidden;
}

.detail-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 18px;
  border-bottom: 1px solid rgba(11, 22, 51, 0.08);
}

.detail-modal-title {
  font-size: 16px;
  font-weight: 600;
  color: #0b1633;
}

.detail-modal-close {
  font-size: 26px;
  line-height: 1;
  color: #aaa;
}

.detail-modal-body {
  flex: 1;
  height: 0;
  min-height: 200px;
  max-height: 58vh;
  padding: 16px 18px;
  box-sizing: border-box;
}

.detail-para {
  margin-bottom: 12px;
}

.detail-para:last-child {
  margin-bottom: 0;
}

.detail-sub-head {
  margin-bottom: 4px;
}

.detail-para-label {
  font-size: 14px;
  font-weight: 600;
  color: #2459ff;
}

.detail-sub-body {
  padding-left: 8px;
  border-left: 3px solid rgba(36, 89, 255, 0.2);
}

.detail-section-ai {
  background: rgba(36, 89, 255, 0.04);
  border-radius: 10px;
  padding: 12px;
}

.detail-placeholder {
  color: #888;
  font-size: 13px;
}

.detail-img {
  width: 100%;
  border-radius: 10px;
  margin-bottom: 14px;
}

.detail-section {
  margin-bottom: 16px;
}

.detail-section-title {
  display: block;
  font-size: 13px;
  font-weight: 600;
  color: #2459ff;
  margin-bottom: 6px;
}

.detail-section-body {
  display: block;
  font-size: 14px;
  line-height: 1.7;
  color: #0b1633;
  white-space: pre-wrap;
  word-break: break-word;
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.detail-modal-confirm {
  margin: 0 18px 18px;
  background: #2459ff;
  color: #fff;
  border-radius: 999px;
  font-size: 15px;
}
