<!--pages/categoryDetail/categoryDetail.wxml-->
<view class="category-detail-page">

  <!-- 分类信息卡片（精确复刻 Web 端 .category-info-card） -->
  <view class="info-section">
    <view class="category-info-card">
      <view class="info-header">
        <view class="category-icon-wrap">
          <text class="category-icon-text">{{categoryIcon}}</text>
        </view>
        <view class="info-details">
          <view class="category-name">{{categoryName}}</view>
          <view class="category-desc-text">{{questions.length === 0 ? '暂无题目' : '共收录 ' + questions.length + ' 道错题'}}</view>
          <view class="category-stats-row">
            <text class="stat-pill">{{questions.length}} 道题目</text>
            <text class="stat-pill">正确率 {{accuracy}}%</text>
          </view>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="action-buttons-row">
        <button class="btn btn-primary action-btn" size="small" bindtap="startPractice" wx:if="{{!isPaperSelectMode}}">开始练习</button>
        <button class="btn {{isPaperSelectMode ? 'btn-primary' : 'btn-secondary'}} action-btn" size="small" bindtap="addToExam">{{isPaperSelectMode ? '确认组卷' : '加入组卷'}}</button>
      </view>
    </view>
  </view>

  <!-- 编辑工具栏（仅保留选择相关操作） -->
  <view class="edit-toolbar">
    <text class="edit-action" wx:if="{{editMode}}" bindtap="toggleSelectAll">{{isAllSelected ? '取消全选' : '全选'}}</text>
    <text class="edit-action" bindtap="toggleEditMode">{{editMode ? '完成' : '编辑'}}</text>
  </view>

  <!-- 筛选栏（对应 Web 端的 van-dropdown-menu） -->
  <view class="filter-section">
    <view class="filter-scroll">
      <view class="filter-chip {{groupByKnowledgePoint ? 'active' : ''}}" bindtap="toggleGroupByKnowledgePoint">{{groupByKnowledgePoint ? '分组中' : '按知识点分组'}}</view>
      <view class="filter-chip {{sortBy === 'latest' ? 'active' : ''}}" bindtap="setSort" data-sort="latest">最新添加</view>
      <view class="filter-chip {{sortBy === 'earliest' ? 'active' : ''}}" bindtap="setSort" data-sort="earliest">最早添加</view>
      <view class="filter-chip {{sortBy === 'difficulty' ? 'active' : ''}}" bindtap="setSort" data-sort="difficulty">难度高</view>
      <view class="filter-chip {{sortBy === 'confidence' ? 'active' : ''}}" bindtap="setSort" data-sort="confidence">置信度高</view>
      <view class="filter-chip {{filterBy === 'all' ? 'active' : ''}}" bindtap="setFilter" data-filter="all">全部</view>
      <view class="filter-chip {{filterBy === 'easy' ? 'active' : ''}}" bindtap="setFilter" data-filter="easy">简单</view>
      <view class="filter-chip {{filterBy === 'medium' ? 'active' : ''}}" bindtap="setFilter" data-filter="medium">中等</view>
      <view class="filter-chip {{filterBy === 'hard' ? 'active' : ''}}" bindtap="setFilter" data-filter="hard">困难</view>
      <view class="filter-chip {{tagFilter === 'all' ? 'active' : ''}}" bindtap="setTagFilter" data-tag="all" wx:if="{{availableTags.length}}">全部知识点</view>
      <view class="filter-chip {{tagFilter === item ? 'active' : ''}}" wx:for="{{availableTags}}" wx:key="*this" bindtap="setTagFilter" data-tag="{{item}}">{{item}}</view>
    </view>
  </view>

  <!-- 知识点分组（对齐 Web 端 knowledge-points-section） -->
  <view class="knowledge-points-section" wx:if="{{groupByKnowledgePoint && knowledgePointGroups.length > 0}}">
    <view class="knowledge-group" wx:for="{{knowledgePointGroups}}" wx:key="name">
      <view class="group-header" bindtap="toggleGroup" data-name="{{item.name}}">
        <text class="group-arrow">{{item.expanded ? '▾' : '▸'}}</text>
        <text class="group-title">{{item.name}}</text>
        <text class="group-count">{{item.count}}题</text>
      </view>
      <view class="group-questions" wx:if="{{item.expanded}}">
        <view class="question-card {{qitem.selected ? 'selected' : ''}}"
          wx:for="{{item.questions}}" wx:for-item="qitem" wx:for-index="qIndex" wx:key="id"
          bindtap="onQuestionTap" data-id="{{qitem.id}}" data-index="{{qitem._displayIndex}}">
          <view class="q-index-tag">{{qIndex + 1}}</view>
          <view class="question-card-body">
            <view class="question-img-frame" wx:if="{{qitem.imageUrl}}"
              catchtap="previewImage" data-url="{{qitem.imageUrl}}">
              <image class="question-img" src="{{qitem.imageUrl}}" mode="aspectFill" lazy-load
                binderror="onQuestionImgError" data-id="{{qitem.id}}"></image>
              <view class="img-zoom-pill">查看原图</view>
            </view>
            <view class="question-text-wrap">
              <text class="question-text">{{qitem.displayContent || qitem.content}}</text>
            </view>
            <view class="question-tags" wx:if="{{qitem.tags && qitem.tags.length}}">
              <text class="custom-tag" wx:for="{{qitem.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
            </view>
            <view class="question-meta">
              <view class="meta-left">
                <text class="badge badge-{{qitem.difficultyClass}}">{{qitem.difficultyText}}</text>
                <text class="add-time">{{qitem.formattedDate}}</text>
              </view>
              <view class="meta-right" wx:if="{{editMode}}">
                <view class="select-box {{qitem.selected ? 'checked' : ''}}">
                  <text class="select-check" wx:if="{{qitem.selected}}">✓</text>
                </view>
              </view>
            </view>
            <button class="ai-toggle-btn" wx:if="{{!editMode}}" catchtap="openAIChat" data-content="{{qitem.content}}">AI答疑</button>
            <view class="ai-box" wx:if="{{qitem.showAI && !editMode}}">
              <view class="ai-title">AI 标准答案与解析</view>
              <view class="ai-subtitle">标准答案：</view>
              <text class="ai-content">{{qitem.aiAnswer || '暂无解答'}}</text>
              <view class="ai-subtitle ai-subtitle-gap">智能解析：</view>
              <text class="ai-content">{{qitem.aiAnalysis || '暂无解析'}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 平铺列表（非分组模式或无分组时） -->
  <view class="questions-section" wx:if="{{!groupByKnowledgePoint || knowledgePointGroups.length === 0}}">
    <view wx:if="{{displayQuestions.length > 0}}">
      <view class="question-card {{item.selected ? 'selected' : ''}}" wx:for="{{displayQuestions}}" wx:key="id"
        bindtap="onQuestionTap" data-id="{{item.id}}" data-index="{{index}}">
        <view class="q-index-tag">{{index + 1}}</view>
        <view class="question-card-body">
          <view class="question-img-frame" wx:if="{{item.imageUrl}}"
            catchtap="previewImage" data-url="{{item.imageUrl}}">
            <image class="question-img" src="{{item.imageUrl}}" mode="aspectFill" lazy-load
              binderror="onQuestionImgError" data-id="{{item.id}}"></image>
            <view class="img-zoom-pill">查看原图</view>
          </view>

          <view class="question-text-wrap">
            <text class="question-text">{{item.displayContent || item.content}}</text>
          </view>

          <view class="question-tags" wx:if="{{item.tags && item.tags.length}}">
            <text class="custom-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
          </view>

          <view class="question-meta">
            <view class="meta-left">
              <text class="badge badge-{{item.difficultyClass}}">{{item.difficultyText}}</text>
              <text class="add-time">{{item.formattedDate}}</text>
            </view>
            <view class="meta-right" wx:if="{{editMode}}">
              <view class="select-box {{item.selected ? 'checked' : ''}}">
                <text class="select-check" wx:if="{{item.selected}}">✓</text>
              </view>
            </view>
          </view>
          <button class="ai-toggle-btn" wx:if="{{!editMode}}" catchtap="openAIChat" data-content="{{item.content}}">AI答疑</button>

          <view class="ai-box" wx:if="{{item.showAI && !editMode}}">
            <view class="ai-title">AI 标准答案与解析</view>
            <view class="ai-subtitle">标准答案：</view>
            <text class="ai-content">{{item.aiAnswer || '暂无解答'}}</text>
            <view class="ai-subtitle ai-subtitle-gap">智能解析：</view>
            <text class="ai-content">{{item.aiAnalysis || '暂无解析'}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 批量操作栏（对齐 Web 端 batch-actions） -->
  <view class="batch-actions" wx:if="{{editMode && selectedCount > 0}}">
    <text class="batch-info">已选择 {{selectedCount}} 道题</text>
    <view class="batch-buttons">
      <button class="btn btn-primary batch-btn" size="mini" bindtap="addToExam">{{isPaperSelectMode ? '确认组卷' : '加入组卷'}}</button>
      <button class="btn btn-danger batch-btn" size="mini" bindtap="batchDelete">删除</button>
    </view>
  </view>

  <!-- 题目详情弹窗（对齐 Web 端 viewQuestion dialog） -->
  <view class="detail-mask" wx:if="{{showDetailModal}}" bindtap="closeDetailModal"></view>
  <view class="detail-modal" wx:if="{{showDetailModal}}">
    <view class="detail-modal-header">
      <text class="detail-modal-title">题目 #{{detailQuestion.displayIndex}}</text>
      <text class="detail-modal-close" bindtap="closeDetailModal">×</text>
    </view>
    <scroll-view scroll-y class="detail-modal-body" enhanced show-scrollbar="{{false}}">
      <image class="detail-img" src="{{detailQuestion.imageUrl}}" mode="widthFix"
        wx:if="{{detailQuestion.imageUrl}}" bindtap="previewDetailImage" data-url="{{detailQuestion.imageUrl}}"></image>

      <view class="detail-section">
        <text class="detail-section-title">题目内容</text>
        <view class="detail-para" wx:for="{{detailQuestion.contentParas}}" wx:for-item="para" wx:key="index">
          <view class="detail-sub-head" wx:if="{{para.sub}}">
            <text class="detail-para-label">（{{para.label}}）</text>
          </view>
          <text class="detail-section-body {{para.sub ? 'detail-sub-body' : ''}}">{{para.text}}</text>
        </view>
      </view>

      <view class="detail-section detail-section-ai">
        <text class="detail-section-title">AI 答案</text>
        <text class="detail-section-body {{detailQuestion.aiStatus === 'pending' && !detailQuestion.hasAiAnswer ? 'detail-placeholder' : ''}}">{{detailQuestion.aiAnswer}}</text>
      </view>

      <view class="detail-section detail-section-ai">
        <text class="detail-section-title">AI 解析</text>
        <text class="detail-section-body {{detailQuestion.aiStatus === 'pending' && !detailQuestion.hasAiAnalysis ? 'detail-placeholder' : ''}}">{{detailQuestion.aiAnalysis}}</text>
      </view>

      <view class="detail-section" wx:if="{{detailQuestion.tags && detailQuestion.tags.length > 0}}">
        <text class="detail-section-title">标签</text>
        <view class="detail-tags">
          <text class="custom-tag" wx:for="{{detailQuestion.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
        </view>
      </view>

      <view class="detail-section">
        <text class="detail-section-title">添加时间</text>
        <text class="detail-section-body">{{detailQuestion.formattedDate}}</text>
      </view>
    </scroll-view>
    <button class="detail-modal-confirm" bindtap="closeDetailModal">关闭</button>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{displayQuestions.length === 0 && knowledgePointGroups.length === 0}}">
    <text class="empty-text" wx:if="{{questions.length === 0}}">当前分类暂无错题</text>
    <text class="empty-text" wx:else>没有匹配的题目</text>
    <button class="btn btn-primary go-back-btn" bindtap="goBackToHome">去拍错题</button>
  </view>
</view>
