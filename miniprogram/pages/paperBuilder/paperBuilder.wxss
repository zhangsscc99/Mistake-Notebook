/* pages/paperBuilder/paperBuilder.wxss */
.form-card {
  margin-top: 16px;
  padding: 16px;
}

.form-item {
  margin-bottom: 16px;
  border-bottom: 1px solid #ebedf0;
  padding-bottom: 8px;
}

.form-label {
  font-size: 14px;
  font-weight: bold;
  color: #646566;
  margin-bottom: 8px;
  display: block;
}

.form-input {
  font-size: 15px;
  width: 100%;
}

.list-card {
  padding: 16px;
}

.list-header {
  border-bottom: 1px solid #f2f3f5;
  padding-bottom: 12px;
  margin-bottom: 12px;
}

.selected-questions-list {
  display: flex;
  flex-direction: column;
}

.question-item {
  border-bottom: 1px solid #f7f8fa;
  padding: 10px 0;
}

.question-item:last-child {
  border-bottom: none;
}

.question-info {
  display: flex;
  flex: 1;
  padding-right: 12px;
}

.q-index {
  font-size: 14px;
  font-weight: bold;
  color: #1989fa;
  margin-right: 6px;
}

.q-content {
  font-size: 14px;
  color: #323233;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.no-questions {
  padding: 40px 0;
}

.btn-group {
  padding: 0 12px 30px 12px;
}

.submit-btn {
  width: 100% !important;
  border-radius: 24px;
}