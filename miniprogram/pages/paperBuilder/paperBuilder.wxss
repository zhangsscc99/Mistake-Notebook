/* pages/paperBuilder/paperBuilder.wxss */

/* ─── 页面基础 ─── */
.paper-builder-page {
  min-height: 100vh;
  padding-bottom: 120px;
  background: #eaf3ff;
}

/* ─── 统计卡片（对齐分类页） ─── */
.stats-section {
  padding: 16px 20px 8px;
}

.stats-card {
  position: relative;
  background: linear-gradient(135deg, #2459ff 0%, #52b7ff 50%, #b6a6ff 100%);
  border-radius: 20px;
  padding: 24px;
  display: flex;
  justify-content: space-around;
  box-shadow:
    0 8px 32px rgba(31, 91, 255, 0.30),
    inset 0 1px 0 rgba(255, 255, 255, 0.20);
  overflow: hidden;
}

.stats-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle 280rpx at 30% 20%, rgba(255, 255, 255, 0.10) 0%, transparent 50%),
    radial-gradient(circle 200rpx at 70% 80%, rgba(255, 255, 255, 0.05) 0%, transparent 50%);
  pointer-events: none;
}

.stat-item {
  text-align: center;
  position: relative;
  z-index: 2;
}

.stat-number {
  display: block;
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 4px;
  color: #ffffff;
}

.stat-label {
  font-size: 12px;
  opacity: 0.90;
  color: #ffffff;
}

/* ─── 组建新卷入口 ─── */
.create-section {
  padding: 8px 20px 4px;
}

.create-btn {
  width: 100% !important;
  height: 46px !important;
  line-height: 46px !important;
  font-size: 15px !important;
  border-radius: 14px !important;
  font-weight: 700 !important;
  background: linear-gradient(135deg, #2459ff, #52b7ff, #b6a6ff) !important;
  color: #ffffff !important;
  border: none !important;
  box-shadow: 0 6px 20px rgba(31, 91, 255, 0.28) !important;
  letter-spacing: 0.5px !important;
}

.create-btn::after {
  border: none !important;
}

/* ─── 当前组卷草稿 ─── */
.draft-section {
  padding: 20px 16px 0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.section-label {
  font-size: 13px;
  font-weight: 700;
  color: rgba(11,22,51,0.45);
  letter-spacing: 0.8px;
  text-transform: uppercase;
}

.draft-clear {
  font-size: 13px;
  color: #2459ff;
  font-weight: 600;
}

.draft-card {
  padding: 18px 18px 14px;
  border-radius: 18px;
  background: rgba(255,255,255,0.88);
  border: 1.5px dashed rgba(36,89,255,0.28);
  box-shadow: 0 6px 20px rgba(31,91,255,0.07);
}

.draft-count {
  display: block;
  font-size: 17px;
  font-weight: 700;
  color: #1a3eb5;
  margin-bottom: 5px;
}

.draft-hint {
  display: block;
  font-size: 12px;
  color: rgba(11,22,51,0.52);
  line-height: 1.6;
  margin-bottom: 14px;
}

.draft-save-btn {
  width: 100% !important;
  height: 42px !important;
  line-height: 42px !important;
  border-radius: 13px !important;
  font-size: 15px !important;
  font-weight: 700 !important;
  background: linear-gradient(135deg, #2459ff, #52b7ff, #b6a6ff) !important;
  color: #ffffff !important;
  border: none !important;
  box-shadow: 0 6px 20px rgba(31,91,255,0.28) !important;
  letter-spacing: 0.5px !important;
}

.draft-save-btn::after {
  border: none !important;
}

/* ─── 试卷列表区 ─── */
.saved-papers-section {
  padding: 20px 16px 0;
}

/* ─── 试卷卡片 ─── */
.paper-card {
  display: flex;
  position: relative;
  background: rgba(255,255,255,0.88);
  border: 1px solid rgba(47,107,255,0.10);
  border-radius: 20px;
  margin-bottom: 14px;
  box-shadow:
    0 2px 0 rgba(255,255,255,0.9) inset,
    0 12px 40px rgba(11,22,51,0.07),
    0 4px 16px rgba(31,91,255,0.05);
  overflow: hidden;
  transition: transform 0.22s ease, box-shadow 0.22s ease;
}

.paper-card:active {
  transform: translateY(-2px) scale(0.99);
  box-shadow:
    0 2px 0 rgba(255,255,255,0.9) inset,
    0 18px 50px rgba(11,22,51,0.11),
    0 6px 24px rgba(31,91,255,0.10);
}

.paper-left-accent {
  width: 5px;
  flex-shrink: 0;
  background: linear-gradient(180deg, #2459ff 0%, #52b7ff 50%, #b6a6ff 100%);
  border-radius: 20px 0 0 20px;
}

.paper-body {
  flex: 1;
  padding: 16px 14px 14px 16px;
  min-width: 0;
}

/* 卡片顶部行：图标 + 标题 + 箭头 */
.paper-header-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 10px;
}

/* 图标圆圈 */
.paper-icon-circle {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  background: linear-gradient(135deg, #2459ff 0%, #52b7ff 50%, #b6a6ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4px 14px rgba(31,91,255,0.28);
}

.paper-icon-text {
  font-size: 16px;
  font-weight: 800;
  color: #ffffff;
  line-height: 1;
  letter-spacing: -0.5px;
}

.paper-info {
  flex: 1;
  min-width: 0;
}

.paper-title-text {
  display: block;
  font-size: 16px;
  font-weight: 700;
  color: #0b1633;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 3px;
  letter-spacing: -0.2px;
}

.paper-meta {
  display: block;
  font-size: 12px;
  color: rgba(11,22,51,0.48);
  font-weight: 500;
}

.paper-arrow {
  font-size: 18px;
  color: rgba(11,22,51,0.28);
  font-weight: 400;
  flex-shrink: 0;
  margin-left: 2px;
}

/* 底部 badge 行 */
.paper-stats-row {
  display: flex;
  gap: 7px;
  flex-wrap: wrap;
}

.stat-badge {
  font-size: 11px;
  font-weight: 600;
  color: #2459ff;
  background: rgba(31,91,255,0.08);
  border: 1px solid rgba(31,91,255,0.16);
  border-radius: 8px;
  padding: 3px 10px;
  letter-spacing: 0.2px;
}

/* ─── 空状态 ─── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 32px 60px;
  text-align: center;
}

.empty-illustration {
  width: 100px;
  height: 100px;
  border-radius: 28px;
  background: linear-gradient(145deg, rgba(36,89,255,0.10) 0%, rgba(82,183,255,0.10) 100%);
  border: 1.5px dashed rgba(36,89,255,0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 22px;
}

.empty-emoji {
  font-size: 44px;
  line-height: 1;
}

.empty-title {
  font-size: 18px;
  font-weight: 700;
  color: #0b1633;
  margin-bottom: 8px;
  letter-spacing: -0.3px;
}

.empty-desc-text {
  font-size: 13px;
  color: rgba(11,22,51,0.50);
  line-height: 1.6;
  margin-bottom: 32px;
}

.empty-action-btn {
  width: 200px !important;
  height: 48px !important;
  font-size: 15px !important;
  font-weight: 700 !important;
  border-radius: 16px !important;
  background: linear-gradient(135deg, #2459ff, #52b7ff, #b6a6ff) !important;
  color: #ffffff !important;
  border: none !important;
  box-shadow: 0 8px 28px rgba(31,91,255,0.32) !important;
  letter-spacing: 0.4px !important;
}

.empty-action-btn::after {
  border: none !important;
}

/* ─── 通用按钮 ─── */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: linear-gradient(135deg, #2459ff, #52b7ff, #b6a6ff) !important;
  color: #ffffff !important;
  border: none !important;
  box-shadow: 0 6px 20px rgba(31,91,255,0.28) !important;
}

.btn-primary::after {
  border: none !important;
}
