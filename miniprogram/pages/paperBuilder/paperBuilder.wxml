<!--pages/paperBuilder/paperBuilder.wxml-->
<view class="paper-builder-page">

  <!-- ── 统计卡片（对齐分类页 stats-card） ── -->
  <view class="stats-section">
    <view class="stats-card">
      <view class="stat-item">
        <text class="stat-number">{{savedPapers.length}}</text>
        <text class="stat-label">试卷数</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{totalQuestionCount}}</text>
        <text class="stat-label">总题数</text>
      </view>
    </view>
  </view>

  <!-- ── 组建新卷入口 ── -->
  <view class="create-section">
    <button class="btn create-btn" bindtap="createNewPaper">＋ 组建新卷</button>
  </view>

  <!-- ── 已保存的试卷列表 ── -->
  <view class="saved-papers-section" wx:if="{{savedPapers.length > 0}}">
    <view class="section-header">
      <text class="section-label">我的试卷</text>
    </view>

    <view class="paper-card"
      wx:for="{{savedPapers}}"
      wx:key="id"
      bindtap="viewPaper"
      data-index="{{index}}">
      <view class="paper-left-accent"></view>
      <view class="paper-body">
        <view class="paper-header-row">
          <view class="paper-icon-circle">
            <text class="paper-icon-text">卷</text>
          </view>
          <view class="paper-info">
            <text class="paper-title-text">{{item.title}}</text>
            <text class="paper-meta">{{item.questionCount}} 道题 · {{item.createdAt}}</text>
          </view>
          <text class="paper-arrow">›</text>
        </view>
        <view class="paper-stats-row">
          <text class="stat-badge">{{item.questionCount}} 题</text>
          <text class="stat-badge">{{item.duration || 90}} 分钟</text>
          <text class="stat-badge" wx:if="{{item.totalScore}}">{{item.totalScore}} 分</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ── 空状态 ── -->
  <view class="empty-state" wx:if="{{savedPapers.length === 0}}">
    <view class="empty-illustration">
      <text class="empty-emoji">📝</text>
    </view>
    <text class="empty-title">还没有试卷</text>
    <text class="empty-desc-text">从错题本里选题，一键组建属于你的试卷</text>
    <button class="btn empty-action-btn" bindtap="createNewPaper">立即组建新卷</button>
  </view>

</view>
