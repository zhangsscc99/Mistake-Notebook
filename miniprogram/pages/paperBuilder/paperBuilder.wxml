<!--pages/paperBuilder/paperBuilder.wxml-->
<view class="paper-builder-page">

  <!-- 页面顶部 Header -->
  <view class="page-header">
    <view class="page-title-row">
      <text class="page-title">智能组卷</text>
    </view>
    <button class="btn btn-primary create-btn" bindtap="createNewPaper">组建新卷</button>
  </view>

  <!-- 已保存的试卷列表 -->
  <view class="saved-papers-section" wx:if="{{savedPapers.length > 0}}">
    <view class="section-header">
      <text class="section-title">我的试卷</text>
    </view>

    <view class="paper-card"
      wx:for="{{savedPapers}}"
      wx:key="id"
      bindtap="viewPaper"
      data-index="{{index}}">
      <view class="paper-left-accent"></view>
      <view class="paper-body">
        <view class="paper-header-row">
          <text class="paper-icon-text">卷</text>
          <view class="paper-info">
            <text class="paper-title-text">{{item.title}}</text>
            <text class="paper-meta">{{item.questionCount}} 道题 · {{item.createdAt}}</text>
          </view>
          <text class="paper-arrow">›</text>
        </view>
        <view class="paper-stats-row">
          <text class="stat-badge">{{item.questionCount}} 题</text>
          <text class="stat-badge">{{item.duration || 90}} 分钟</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{savedPapers.length === 0}}">
    <text class="empty-desc-text">还没有组建试卷</text>
    <button class="empty-action-btn" bindtap="createNewPaper">立即组建新卷</button>
  </view>

</view>
