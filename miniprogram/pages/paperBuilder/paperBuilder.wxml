<!--pages/paperBuilder/paperBuilder.wxml-->
<view class="container">
  <view class="card form-card">
    <view class="section-title text-primary" style="margin: 0 0 16px 0;">试卷设置</view>
    
    <view class="form-item">
      <text class="form-label">试卷名称</text>
      <input class="form-input" placeholder="例如：期末复习错题集" value="{{title}}" bindinput="onTitleInput" />
    </view>

    <view class="form-item">
      <text class="form-label">答卷时间 (分钟)</text>
      <slider min="30" max="180" step="5" value="{{duration}}" show-value activeColor="#1989fa" bindchange="onDurationChange"></slider>
    </view>

    <view class="form-item">
      <text class="form-label">试卷总分</text>
      <input class="form-input" type="number" placeholder="例如：100" value="{{totalScore}}" bindinput="onScoreInput" />
    </view>
  </view>

  <!-- 题目列表 -->
  <view class="card list-card">
    <view class="list-header justify-between align-center">
      <view>
        <text class="section-title" style="margin: 0;">已选择题目</text>
        <text class="text-desc" style="margin-left: 8px;">共 {{selectedQuestions.length}} 题</text>
      </view>
      <button class="btn btn-secondary btn-sm" bindtap="goToSelector">+ 选择题目</button>
    </view>

    <view class="selected-questions-list" wx:if="{{selectedQuestions.length > 0}}">
      <view class="question-item justify-between align-center" wx:for="{{selectedQuestions}}" wx:key="id">
        <view class="question-info">
          <text class="q-index">{{index + 1}}.</text>
          <text class="q-content">{{item.content}}</text>
        </view>
        <image class="remove-icon" src="../../images/remove.png" mode="aspectFit" style="width: 20px; height: 20px; padding: 4px;" bindtap="removeQuestion" data-index="{{index}}"></image>
      </view>
    </view>

    <view class="no-questions justify-center align-center" wx:else>
      <text class="text-desc">还没有添加题目，点击上方“选择题目”添加</text>
    </view>
  </view>

  <view class="btn-group">
    <button class="btn btn-primary submit-btn" loading="{{generating}}" disabled="{{selectedQuestions.length === 0 || generating}}" bindtap="generatePaper">
      {{generating ? '正在生成 PDF...' : '一键生成试卷 PDF'}}
    </button>
  </view>
</view>