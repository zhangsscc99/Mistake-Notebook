/* pages/aiChat/aiChat.wxss */
.ai-chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  background-color: #eef3fb;
  background-image:
    radial-gradient(circle 420rpx at 100% 0%, rgba(82, 183, 255, 0.12) 0%, transparent 60%),
    radial-gradient(circle 360rpx at 0% 4%, rgba(182, 166, 255, 0.10) 0%, transparent 55%),
    linear-gradient(rgba(11, 22, 51, 0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(11, 22, 51, 0.025) 1px, transparent 1px);
  background-size: auto, auto, 44rpx 44rpx, 44rpx 44rpx;
}

/* 题目上下文条 */
.context-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 20rpx 24rpx 0;
  padding: 20rpx 22rpx;
  background: #ffffff;
  border-radius: 18rpx;
  border: 1px solid rgba(11, 22, 51, 0.06);
  box-shadow: 0 12rpx 36rpx rgba(11, 22, 51, 0.06);
}

.context-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  background: linear-gradient(140deg, #2459ff 0%, #52b7ff 55%, #b6a6ff 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(31, 91, 255, 0.30);
}

.context-body {
  display: flex;
  flex-direction: column;
  min-width: 0;
  flex: 1;
}

.context-label {
  font-size: 22rpx;
  color: #2459ff;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.context-text {
  font-size: 26rpx;
  color: rgba(11, 22, 51, 0.6);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.context-chevron {
  flex-shrink: 0;
  align-self: center;
  font-size: 23rpx;
  font-weight: 700;
  color: #ffffff;
  padding: 8rpx 22rpx;
  background: linear-gradient(135deg, #2459ff 0%, #52b7ff 100%);
  border-radius: 999rpx;
  box-shadow: 0 6rpx 16rpx rgba(31, 91, 255, 0.28);
}

/* 题目详情浮窗 */
.context-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  background: rgba(11, 22, 51, 0.45);
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.22s ease;
}

.context-modal.show {
  opacity: 1;
  visibility: visible;
}

.context-modal-card {
  width: 100%;
  max-width: 620rpx;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 30rpx 80rpx rgba(11, 22, 51, 0.30);
  transform: scale(0.92);
  transition: transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.context-modal.show .context-modal-card {
  transform: scale(1);
}

.modal-card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 26rpx 26rpx 20rpx;
  border-bottom: 1px solid rgba(11, 22, 51, 0.06);
}

.modal-card-badge {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  background: linear-gradient(140deg, #2459ff 0%, #52b7ff 55%, #b6a6ff 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(31, 91, 255, 0.28);
}

.modal-card-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 800;
  color: #0b1633;
  letter-spacing: 0.5rpx;
}

.modal-card-close {
  width: 52rpx;
  height: 52rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: rgba(11, 22, 51, 0.45);
  background: rgba(11, 22, 51, 0.05);
  border-radius: 50%;
}

.modal-card-scroll {
  box-sizing: border-box;
  width: 100%;
  max-height: calc(70vh - 100rpx);
}

.modal-card-inner {
  box-sizing: border-box;
  width: 100%;
  padding: 22rpx 26rpx 28rpx;
}

/* 结构化题目段落 */
.q-para {
  box-sizing: border-box;
  width: 100%;
}

.q-para-stem {
  font-size: 29rpx;
  line-height: 1.75;
  color: #1a2440;
}

.q-para-stem + .q-para-stem {
  margin-top: 16rpx;
}

.q-para-sub {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
  padding: 18rpx 18rpx 18rpx 16rpx;
  background: rgba(36, 89, 255, 0.04);
  border-radius: 14rpx;
  border-left: 5rpx solid #2459ff;
}

.q-para-label {
  flex-shrink: 0;
  min-width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 10rpx;
  background: linear-gradient(135deg, #2459ff, #52b7ff);
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
}

.q-para-text {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.7;
  color: #1a2440;
  white-space: pre-wrap;
  word-break: break-word;
  overflow-wrap: anywhere;
}

.q-para-stem .q-para-text {
  font-size: 29rpx;
}

/* 消息区 */
.msg-scroll {
  flex: 1;
  min-height: 0;
}

.msg-list {
  padding: 28rpx 24rpx 16rpx;
}

.msg-row {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.msg-row-user {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.msg-avatar-ai {
  background: linear-gradient(135deg, #2459ff 0%, #52b7ff 100%);
  color: #fff;
  box-shadow: 0 8rpx 18rpx rgba(31, 91, 255, 0.28);
}

.msg-avatar-user {
  background: #ffffff;
  color: #2459ff;
  box-shadow: inset 0 0 0 2rpx rgba(36, 89, 255, 0.25);
}

.msg-bubble {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 22rpx;
  font-size: 29rpx;
  line-height: 1.6;
}

.bubble-ai {
  background: #ffffff;
  color: #1a2440;
  border-bottom-left-radius: 6rpx;
  border: 1px solid rgba(11, 22, 51, 0.05);
  box-shadow: 0 10rpx 30rpx rgba(11, 22, 51, 0.06);
}

.bubble-user {
  background: linear-gradient(135deg, #2459ff 0%, #52b7ff 100%);
  color: #ffffff;
  border-bottom-right-radius: 6rpx;
  box-shadow: 0 10rpx 26rpx rgba(31, 91, 255, 0.30);
}

.msg-text {
  white-space: pre-wrap;
  word-break: break-word;
}

/* 输入中的省略点动画 */
.typing {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 6rpx 2rpx;
}

.typing .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(36, 89, 255, 0.45);
  animation: typing-bounce 1.2s infinite ease-in-out;
}

.typing .dot:nth-child(2) { animation-delay: 0.2s; }
.typing .dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typing-bounce {
  0%, 80%, 100% { transform: translateY(0); opacity: 0.4; }
  40% { transform: translateY(-8rpx); opacity: 1; }
}

.scroll-pad {
  width: 100%;
}

/* 底部输入栏 */
.input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-top: 1px solid rgba(11, 22, 51, 0.06);
  transition: transform 0.18s ease-out;
}

.chat-input {
  flex: 1;
  height: 76rpx;
  padding: 0 28rpx;
  background: #f1f4fb;
  border-radius: 999rpx;
  font-size: 29rpx;
  color: #0b1633;
}

.input-placeholder {
  color: rgba(11, 22, 51, 0.38);
}

.send-btn {
  flex-shrink: 0;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 36rpx;
  border-radius: 999rpx;
  font-size: 29rpx;
  font-weight: 700;
  color: #ffffff;
  background: rgba(36, 89, 255, 0.30);
  border: none;
  transition: background 0.2s, box-shadow 0.2s;
}

.send-btn::after {
  border: none;
}

.send-btn-active {
  background: linear-gradient(135deg, #2459ff 0%, #52b7ff 100%);
  box-shadow: 0 8rpx 20rpx rgba(31, 91, 255, 0.30);
}
