<view class="picker-page">
  <view class="tips-bar">
    <text class="tips-text">已自动选中疑难题目，可点击勾选或取消</text>
  </view>

  <view class="image-section image-overlay-wrap" wx:if="{{imagePath}}">
    <image class="preview-image" src="{{imagePath}}" mode="widthFix"></image>
    <view
      class="question-overlay {{item.selected ? 'selected' : ''}}"
      wx:for="{{questions}}"
      wx:key="id"
      wx:if="{{item.bounds}}"
      style="top: {{item.bounds.top}}%; left: {{item.bounds.left}}%; width: {{item.bounds.width}}%; height: {{item.bounds.height}}%;"
      catchtap="toggleQuestionOverlay"
      data-id="{{item.id}}"
    >
      <text class="overlay-index">{{index + 1}}</text>
    </view>
  </view>

  <view class="questions-section">
    <checkbox-group bindchange="onQuestionChange">
      <label class="question-card" wx:for="{{questions}}" wx:key="id">
        <checkbox value="{{item.id}}" checked="{{item.selected}}" color="#2459ff" />
        <view class="question-body">
          <view class="question-meta">
            <text class="question-index">第{{index + 1}}题</text>
            <text class="question-type" wx:if="{{item.type}}">{{item.type}}</text>
            <text class="confidence-badge" wx:if="{{item.confidence}}">{{item.confidenceLabel}}</text>
          </view>
          <text class="question-text">{{item.text}}</text>
        </view>
      </label>
    </checkbox-group>
  </view>

  <view class="bottom-bar">
    <view class="bottom-bar-header">
      <view class="bottom-meta">
        <text class="bottom-category-text">{{selectedCategory}}</text>
        <text class="bottom-dot">·</text>
        <text class="bottom-difficulty-text">{{selectedDifficulty}}</text>
      </view>
      <text class="modify-btn" bindtap="openCategoryPicker">修改 ›</text>
    </view>

    <button class="save-btn" loading="{{saving}}" disabled="{{saving || selectedCount === 0}}" bindtap="saveSelected">
      保存到错题本 ({{selectedCount}})
    </button>
  </view>

  <!-- 修改分类弹窗 -->
  <view class="picker-mask" wx:if="{{showPickerModal}}" bindtap="closePickerModal">
  </view>
  <view class="picker-modal" wx:if="{{showPickerModal}}">
    <view class="picker-modal-header">
      <text class="picker-modal-title">编辑分类信息</text>
      <text class="picker-modal-close" bindtap="closePickerModal">×</text>
    </view>

    <view class="picker-section">
      <view class="picker-section-label">学科分类</view>
      <scroll-view scroll-x class="picker-chip-scroll">
        <view
          class="picker-chip {{tempCategory === item.name ? 'active' : ''}}"
          wx:for="{{categories}}"
          wx:key="name"
          bindtap="onTempCategorySelect"
          data-name="{{item.name}}"
        >{{item.name}}</view>
      </scroll-view>
    </view>

    <view class="picker-section">
      <view class="picker-section-label">难度等级</view>
      <view class="picker-chip-row">
        <view
          class="picker-chip {{tempDifficulty === item ? 'active' : ''}}"
          wx:for="{{difficulties}}"
          wx:key="*this"
          bindtap="onTempDifficultySelect"
          data-value="{{item}}"
        >{{item}}</view>
      </view>
    </view>

    <view class="picker-section">
      <view class="picker-section-label">学习阶段</view>
      <view class="picker-chip-row">
        <view
          class="picker-chip {{tempPeriod === item ? 'active' : ''}}"
          wx:for="{{periods}}"
          wx:key="*this"
          bindtap="onTempPeriodSelect"
          data-value="{{item}}"
        >{{item}}</view>
      </view>
    </view>

    <view class="picker-modal-actions">
      <button class="picker-cancel-btn" bindtap="closePickerModal">取消</button>
      <button class="picker-confirm-btn" bindtap="confirmPickerModal">确认</button>
    </view>
  </view>
</view>
