.picker-page {
  min-height: 100vh;
  padding-bottom: 280rpx;
  background: #eaf3ff;
}

.tips-bar {
  margin: 24rpx 24rpx 0;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(36, 89, 255, 0.08);
}

.tips-text {
  font-size: 26rpx;
  color: #2459ff;
}

.image-section {
  margin: 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 8rpx 32rpx rgba(31, 91, 255, 0.08);
}

.image-overlay-wrap {
  position: relative;
}

.preview-image {
  width: 100%;
  display: block;
}

.question-overlay {
  position: absolute;
  box-sizing: border-box;
  border: 3rpx solid rgba(36, 89, 255, 0.75);
  border-radius: 12rpx;
  background: rgba(36, 89, 255, 0.08);
}

.question-overlay.selected {
  border-color: #2459ff;
  background: rgba(36, 89, 255, 0.22);
  box-shadow: 0 0 0 4rpx rgba(36, 89, 255, 0.15);
}

.overlay-index {
  position: absolute;
  top: 6rpx;
  left: 8rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #fff;
  background: linear-gradient(135deg, #2459ff, #52b7ff, #b6a6ff);
}

.questions-section {
  padding: 0 24rpx;
}

.question-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 24rpx rgba(11, 22, 51, 0.05);
}

.question-body {
  flex: 1;
}

.question-meta {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.question-index,
.question-type {
  font-size: 22rpx;
  color: #2459ff;
}

.confidence-badge {
  font-size: 20rpx;
  color: #888;
  background: #f3f3f3;
  border-radius: 20rpx;
  padding: 2rpx 12rpx;
}

.question-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #0b1633;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 32rpx rgba(11, 22, 51, 0.08);
}

.bottom-bar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.bottom-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.bottom-category-text,
.bottom-difficulty-text {
  font-size: 28rpx;
  color: #0b1633;
  font-weight: 500;
}

.bottom-dot {
  font-size: 24rpx;
  color: #aaa;
}

.modify-btn {
  font-size: 26rpx;
  color: #2459ff;
}

.save-btn {
  background: #2459ff;
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
}

/* ---- 分类弹窗 ---- */
.picker-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
}

.picker-modal {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  padding: 32rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
}

.picker-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.picker-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0b1633;
}

.picker-modal-close {
  font-size: 44rpx;
  color: #aaa;
  line-height: 1;
}

.picker-section {
  margin-bottom: 28rpx;
}

.picker-section-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 14rpx;
}

.picker-chip-scroll {
  white-space: nowrap;
}

.picker-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.picker-chip {
  display: inline-block;
  margin-right: 16rpx;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #0b1633;
  background: #f3f6ff;
}

.picker-chip.active {
  color: #fff;
  background: linear-gradient(135deg, #2459ff, #52b7ff, #b6a6ff);
}

.picker-modal-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 8rpx;
}

.picker-cancel-btn {
  flex: 1;
  border-radius: 999rpx;
  font-size: 28rpx;
  color: #2459ff;
  background: #eef3ff;
  border: none;
}

.picker-confirm-btn {
  flex: 2;
  border-radius: 999rpx;
  font-size: 28rpx;
  color: #fff;
  background: linear-gradient(135deg, #2459ff, #52b7ff, #b6a6ff);
  border: none;
  box-shadow: 0 4px 16px rgba(31, 91, 255, 0.25);
}
