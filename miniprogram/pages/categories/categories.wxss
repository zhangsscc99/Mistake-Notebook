/* pages/categories/categories.wxss */
.categories-page {
  min-height: 100vh;
  padding-bottom: 60px;
  background: #eaf3ff;
}

/* 搜索栏 — 复刻 van-search */
.search-section {
  padding: 8px 16px 16px 16px;
  background: #eaf3ff;
}

.search-box {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(47, 107, 255, 0.22);
  border-radius: 16px;
  box-shadow:
    0 10px 35px rgba(31, 91, 255, 0.06);
  padding: 0 12px;
  height: 44px;
}

.search-icon-wrap {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 6px;
  flex-shrink: 0;
}

.search-icon {
  font-size: 16px;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 14px;
  font-weight: 500;
  color: #0b1633;
  background: transparent;
  height: 44px;
  line-height: 44px;
}

.search-input::placeholder {
  color: rgba(11, 22, 51, 0.38);
}

.search-action {
  font-size: 14px;
  font-weight: 600;
  color: #1f5bff;
  padding: 0 4px 0 14px;
  border-left: 1px solid rgba(47, 107, 255, 0.14);
  margin-left: 4px;
  line-height: 28px;
}

/* 统计卡片 */
.stats-section {
  padding: 8px 20px 20px 20px;
}

.stats-card {
  position: relative;
  background: linear-gradient(135deg, #2459ff 0%, #52b7ff 50%, #b6a6ff 100%);
  color: #eaf3ff;
  border-radius: 20px;
  padding: 24px;
  display: flex;
  justify-content: space-around;
  box-shadow:
    0 8px 32px rgba(31, 91, 255, 0.30),
    inset 0 1px 0 rgba(255, 255, 255, 0.20);
  overflow: hidden;
}

.stats-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle 280rpx at 30% 20%, rgba(255, 255, 255, 0.10) 0%, transparent 50%),
    radial-gradient(circle 200rpx at 70% 80%, rgba(255, 255, 255, 0.05) 0%, transparent 50%);
  pointer-events: none;
}


.stat-item {
  text-align: center;
  position: relative;
  z-index: 2;
}

.stat-number {
  display: block;
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 4px;
  color: #ffffff;
}

.stat-label {
  font-size: 12px;
  opacity: 0.90;
  color: #ffffff;
}

/* 分类列表 */
.categories-section {
  padding: 0 20px;
}

.category-card {
  position: relative;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(47, 107, 255, 0.14);
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 16px;
  box-shadow:
    0 10px 35px rgba(31, 91, 255, 0.06),
    0 14px 44px rgba(11, 22, 51, 0.06),
    inset 0 1px 0 rgba(255, 255, 255, 0.55);
  overflow: hidden;
  transition: all 0.3s ease;
}

.category-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4px;
  height: 100%;
  background: linear-gradient(180deg, #2459ff 0%, #52b7ff 50%, #b6a6ff 100%);
  border-radius: 16px 0 0 16px;
  box-shadow: 0 0 8px rgba(31, 91, 255, 0.50);
}

.category-card:active {
  border-color: rgba(47, 107, 255, 0.22);
  box-shadow:
    0 0 40px rgba(31, 91, 255, 0.15),
    0 20px 70px rgba(11, 22, 51, 0.10),
    inset 0 1px 0 rgba(255, 255, 255, 0.55);
  transform: translateY(-3px);
}

/* 卡片头部 — 图标+标题+数量 */
.category-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12px;
}

.category-icon {
  width: 44px;
  height: 44px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
  flex-shrink: 0;
}

.category-icon-text {
  font-size: 16px;
  font-weight: bold;
  color: #2459ff;
}

.category-info {
  flex: 1;
  min-width: 0;
}

.category-title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 4px;
  background: linear-gradient(135deg, #0b1633, #1f5bff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}


.category-count {
  text-align: center;
  margin-left: 12px;
  flex-shrink: 0;
}

.count-number {
  display: block;
  font-size: 20px;
  font-weight: bold;
  color: #1f5bff;
  text-shadow: 0 0 8px rgba(31, 91, 255, 0.30);
}

.count-label {
  font-size: 12px;
  color: rgba(11, 22, 51, 0.62);
}

/* 标签 */
.category-tags {
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}

.custom-tag {
  font-size: 12px;
  padding: 2px 8px;
  border-radius: 6px;
  background: rgba(31, 91, 255, 0.15);
  color: #1f5bff;
  border: 1px solid rgba(31, 91, 255, 0.30);
}

.more-tags {
  font-size: 12px;
  color: rgba(11, 22, 51, 0.50);
}

/* 底部 footer */
.category-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid rgba(11, 22, 51, 0.06);
  padding-top: 12px;
}

.last-updated {
  font-size: 12px;
  color: rgba(11, 22, 51, 0.62);
  font-weight: 500;
}

.footer-arrow {
  font-size: 18px;
  color: rgba(11, 22, 51, 0.35);
  font-weight: 300;
  line-height: 1;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 20px;
  text-align: center;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 16px;
  color: rgba(11, 22, 51, 0.62);
  margin-bottom: 24px;
}

.go-camera-btn {
  width: 160px !important;
  border-radius: 20px !important;
}

.paper-mode-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 12px 16px 0;
  padding: 14px 16px;
  border-radius: 16px;
  background: rgba(36, 89, 255, 0.1);
  border: 1px solid rgba(36, 89, 255, 0.22);
}

.paper-mode-text {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.paper-mode-title {
  font-size: 15px;
  font-weight: 700;
  color: #2459ff;
}

.paper-mode-desc {
  font-size: 12px;
  color: rgba(11, 22, 51, 0.62);
}

.paper-mode-cancel {
  font-size: 13px;
  color: rgba(11, 22, 51, 0.55);
  padding: 4px 8px;
}
