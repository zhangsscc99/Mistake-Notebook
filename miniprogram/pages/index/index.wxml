<!--pages/index/index.wxml-->
<view class="index-page">
  <!-- 多色背景光晕层 -->
  <view class="bg-blob bg-blob-blue"></view>
  <view class="bg-blob bg-blob-pink"></view>
  <view class="bg-blob bg-blob-purple"></view>
  <view class="bg-blob bg-blob-peach"></view>

  <view class="main-section">
    <view class="content-container">

      <!-- 产品介绍（无图片时） -->
      <view class="product-guide" wx:if="{{!tempFilePath}}">
        <view class="guide-header">
          <view class="guide-title">错题本整理助手</view>
          <view class="guide-subtitle">智能识别 · 自动分类 · 高效复习</view>
        </view>

        <view class="guide-features">
          <view class="feature-item">
            <view class="feature-text">
              <view class="feature-h4">拍照识别</view>
              <view class="feature-p">一键拍摄错题，AI自动识别文字内容</view>
            </view>
          </view>
          <view class="feature-item">
            <view class="feature-text">
              <view class="feature-h4">智能分类</view>
              <view class="feature-p">大模型自动分析题目类型并归类整理</view>
            </view>
          </view>
          <view class="feature-item">
            <view class="feature-text">
              <view class="feature-h4">组卷练习</view>
              <view class="feature-p">自由组合错题生成试卷，支持打印导出</view>
            </view>
          </view>
        </view>
      </view>

      <!-- 已选择的图片预览（对齐 Web 端 Camera.vue） -->
      <view class="image-preview-area" wx:if="{{tempFilePath}}">
        <view class="image-grid">
          <view class="image-item">
            <image class="preview-image" src="{{tempFilePath}}" mode="aspectFill"></image>
            <view class="image-overlay">
              <view class="remove-icon" bindtap="resetImage">×</view>
            </view>
          </view>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="action-area">
        <view class="action-buttons">
          <button class="action-btn action-btn-primary" bindtap="chooseImage">开始拍照</button>
          <button class="action-btn action-btn-default" bindtap="chooseImage">从相册选择</button>
        </view>
        <button class="process-btn" wx:if="{{tempFilePath}}"
          loading="{{uploading}}" disabled="{{uploading}}" bindtap="submitQuestion">
          {{uploading ? 'AI识别中...' : '开始识别 (1张)'}}
        </button>
      </view>

    </view>
  </view>
</view>
