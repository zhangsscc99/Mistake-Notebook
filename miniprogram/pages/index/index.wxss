/* pages/index/index.wxss */

/* ── 全页背景 ─────────────────────────────── */
.index-page {
  min-height: 100vh;
  padding-bottom: 80px;
  position: relative;
  overflow: hidden;
  background: #eaf3ff;
}

/* 顶部导航栏 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 16rpx 28rpx 8rpx;
  position: relative;
  z-index: 10;
}

.top-bar-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #0b1633;
  letter-spacing: 1rpx;
}

.top-bar-settings {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.7);
  box-shadow: 0 2rpx 12rpx rgba(36,89,255,0.1);
}

/* 多色流光光晕（完全复刻 Camera.vue 的 radial-gradient blobs） */
.bg-blob {
  position: fixed;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
  filter: blur(60px);
  opacity: 0.55;
}
.bg-blob-blue {
  width: 680rpx;
  height: 520rpx;
  left: -80rpx;
  top: -60rpx;
  background: radial-gradient(ellipse, rgba(36, 89, 255, 0.45) 0%, transparent 70%);
}
.bg-blob-pink {
  width: 600rpx;
  height: 480rpx;
  right: -80rpx;
  top: -40rpx;
  background: radial-gradient(ellipse, rgba(255, 123, 208, 0.45) 0%, transparent 70%);
}
.bg-blob-purple {
  width: 640rpx;
  height: 520rpx;
  left: -60rpx;
  bottom: 80rpx;
  background: radial-gradient(ellipse, rgba(138, 125, 255, 0.40) 0%, transparent 70%);
}
.bg-blob-peach {
  width: 560rpx;
  height: 420rpx;
  right: -60rpx;
  bottom: 120rpx;
  background: radial-gradient(ellipse, rgba(255, 181, 106, 0.38) 0%, transparent 70%);
}

/* ── 主内容区 ─────────────────────────────── */
.main-section {
  padding: 16px;
  position: relative;
  z-index: 1;
}

/* 玻璃容器（完全复刻 .content-container.tech-card） */
.content-container {
  position: relative;
  padding: 24px 20px;
  border-radius: 20px;
  border: 1px solid rgba(255, 255, 255, 0.55);
  /* 和 web 一致的 lavender-to-rose 渐变玻璃背景 */
  background: linear-gradient(
    135deg,
    rgba(246, 236, 255, 0.58),
    rgba(255, 255, 255, 0.48) 46%,
    rgba(255, 235, 248, 0.34)
  );
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  box-shadow:
    0 20px 70px rgba(31, 91, 255, 0.12),
    0 34px 120px rgba(255, 123, 208, 0.10),
    inset 0 1px 0 rgba(255, 255, 255, 0.55),
    0 14px 44px rgba(11, 22, 51, 0.06);
}

/* ── 产品介绍区 ────────────────────────────── */
.product-guide {
  text-align: center;
  margin-bottom: 28px;
  position: relative;
  z-index: 2;
}

.guide-header {
  margin-bottom: 24px;
}

/* 标题：和 web 一致的渐变蓝 shimmer 标题 */
.guide-title {
  font-size: 24px;
  font-weight: 800;
  color: #1f5bff;
  margin-bottom: 10px;
  letter-spacing: -0.3px;
}

.guide-subtitle {
  font-size: 16px;
  color: rgba(11, 22, 51, 0.70);
  font-weight: 600;
}

/* Feature 卡片：和 web 完全一致的纯白小卡片 */
.guide-features {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 24px;
  text-align: left;
}

.feature-item {
  padding: 14px 16px;
  /* web 端是纯白 + 微弱 border */
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.60));
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.60);
  box-shadow:
    0 8px 22px rgba(11, 22, 51, 0.06),
    inset 0 1px 0 rgba(255, 255, 255, 0.70);
}

/* h4 对应 web 的 .feature-text h4 */
.feature-h4 {
  font-size: 16px;
  font-weight: 600;
  color: #0b1633;
  margin-bottom: 6px;
}

/* p 对应 web 的 .feature-text p */
.feature-p {
  font-size: 14px;
  color: rgba(11, 22, 51, 0.62);
  line-height: 1.4;
}

/* ── 操作按钮区 ────────────────────────────── */
.action-area {
  position: relative;
  z-index: 2;
}

.action-buttons {
  display: flex;
  gap: 14px;
}

/* 精确复刻 web 端 .action-buttons .van-button */
.action-btn {
  flex: 1;
  height: 52px;
  line-height: 52px;
  border-radius: 12px !important;
  font-size: 15px;
  font-weight: 600;
  padding: 0 !important;
  text-align: center;
  border: none;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  transition: all 0.22s ease;
}

.action-btn::after {
  border: none !important;
}

/* 主要按钮（品牌渐变） */
.action-btn-primary {
  background: linear-gradient(135deg, #2459ff 0%, #52b7ff 50%, #b6a6ff 100%) !important;
  color: #ffffff !important;
  border: none !important;
  box-shadow:
    0 8px 28px rgba(31, 91, 255, 0.32),
    inset 0 1px 0 rgba(255, 255, 255, 0.22) !important;
}

/* 次要按钮（白色磨砂）— 对应 .van-button--default */
.action-btn-default {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.44), rgba(255, 255, 255, 0.16)) !important;
  color: rgba(11, 22, 51, 0.78) !important;
  border: 1px solid rgba(255, 255, 255, 0.58) !important;
  box-shadow:
    0 14px 34px rgba(11, 22, 51, 0.10),
    inset 0 1px 0 rgba(255, 255, 255, 0.55) !important;
}

.action-btn:active {
  transform: translateY(-1px) scale(0.99);
  opacity: 0.92;
}

/* ── 图片预览区：对齐 Web 端 Camera.vue ───── */
.image-preview-area {
  margin-bottom: 30px;
  position: relative;
  z-index: 2;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: 16px;
}

.image-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid rgba(47, 107, 255, 0.14);
  box-shadow: 0 10px 35px rgba(31, 91, 255, 0.08);
}

.preview-image {
  width: 100%;
  height: 100%;
}

.image-overlay {
  position: absolute;
  inset: 0;
  background: rgba(11, 22, 51, 0.20);
  display: flex;
  align-items: flex-start;
  justify-content: flex-end;
  padding: 8px;
}

.remove-icon {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  color: rgba(11, 22, 51, 0.92);
  box-shadow: 0 10px 26px rgba(11, 22, 51, 0.20);
  font-size: 20px;
  line-height: 26px;
  text-align: center;
  font-weight: 300;
}

.process-btn {
  margin: 12px 0 0;
  display: flex !important;
  align-items: center;
  justify-content: center;
  min-width: 100% !important;
  max-width: 100% !important;
  width: 100% !important;
  height: 52px;
  padding: 0 !important;
  box-sizing: border-box;
  border-radius: 16px !important;
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.44), rgba(255, 255, 255, 0.16)) !important;
  border: 1px solid rgba(47, 107, 255, 0.24) !important;
  color: rgba(31, 91, 255, 0.92) !important;
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  box-shadow:
    0 22px 54px rgba(31, 91, 255, 0.16),
    0 12px 30px rgba(11, 22, 51, 0.10),
    inset 0 1px 0 rgba(255, 255, 255, 0.62) !important;
  font-size: 15px;
  font-weight: 600;
}

.process-btn::after {
  border: none !important;
}

/* 最近处理 */
.recent-section {
  padding: 8px 20px 24px;
  position: relative;
  z-index: 2;
}

.recent-divider {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
}

.divider-line {
  flex: 1;
  height: 1px;
  background: rgba(47, 107, 255, 0.15);
}

.divider-text {
  font-size: 13px;
  color: rgba(11, 22, 51, 0.45);
  white-space: nowrap;
}

.recent-list {
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(12px);
  border: 1px solid rgba(47, 107, 255, 0.1);
  border-radius: 16px;
  overflow: hidden;
}

.recent-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px;
  border-bottom: 1px solid rgba(11, 22, 51, 0.06);
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-info {
  flex: 1;
  min-width: 0;
  margin-right: 8px;
}

.recent-title {
  display: block;
  font-size: 14px;
  color: #0b1633;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 3px;
}

.recent-time {
  display: block;
  font-size: 12px;
  color: rgba(11, 22, 51, 0.45);
}

.recent-arrow {
  font-size: 20px;
  color: rgba(11, 22, 51, 0.3);
  flex-shrink: 0;
}
