/* pages/index/index.wxss */
.header {
  padding: 24px 20px;
  color: #ffffff;
  border-bottom-left-radius: 16px;
  border-bottom-right-radius: 16px;
}

.header-title {
  font-size: 22px;
  font-weight: bold;
}

.header-subtitle {
  font-size: 13px;
  margin-top: 8px;
  opacity: 0.9;
}

.upload-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
  border: 2px dashed #dcdee0;
  background-color: #ffffff;
  margin-top: 16px;
}

.upload-text {
  font-size: 15px;
  color: #323233;
  font-weight: 500;
}

.preview-card {
  padding: 12px;
}

.preview-header {
  font-size: 14px;
  margin-bottom: 8px;
}

.preview-title {
  font-weight: bold;
}

.preview-img {
  width: 100%;
  height: 240px;
  border-radius: 4px;
  background-color: #f7f8fa;
}

.form-card {
  padding: 16px;
}

.form-item {
  margin-bottom: 16px;
  border-bottom: 1px solid #ebedf0;
  padding-bottom: 8px;
}

.form-label {
  font-size: 14px;
  font-weight: bold;
  color: #646566;
  margin-bottom: 6px;
  display: block;
}

.form-input {
  font-size: 15px;
  width: 100%;
}

.picker-val {
  font-size: 15px;
  color: #323233;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 4px 0;
}

.picker-arrow {
  font-size: 10px;
  color: #969799;
}

.options-container {
  margin-top: 12px;
  border-top: 1px solid #ebedf0;
  padding-top: 12px;
}

.option-item {
  margin-bottom: 12px;
}

.option-title {
  font-size: 14px;
  font-weight: 500;
}

.option-desc {
  font-size: 12px;
  color: #969799;
  margin-top: 2px;
}

.submit-btn {
  width: 100% !important;
  margin-top: 20px;
  border-radius: 24px;
}

.result-card {
  background-color: #f0f9eb;
  border: 1px solid #e1f3d8;
}

.result-title {
  font-weight: bold;
  font-size: 15px;
  margin-bottom: 10px;
}

.result-item {
  font-size: 13px;
  margin-bottom: 6px;
}

.result-label {
  font-weight: bold;
  color: #646566;
}

.result-text {
  display: block;
  background-color: #ffffff;
  padding: 8px;
  border-radius: 4px;
  margin-top: 4px;
  font-family: monospace;
  white-space: pre-wrap;
  word-break: break-all;
}