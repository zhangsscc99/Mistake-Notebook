/* pages/settings/settings.wxss */
.user-header {
  display: flex;
  padding: 30px 20px;
  align-items: center;
  border-bottom-left-radius: 16px;
  border-bottom-right-radius: 16px;
}

.avatar-container {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  overflow: hidden;
  border: 3px solid rgba(255, 255, 255, 0.4);
  background-color: #f7f8fa;
}

.user-avatar {
  width: 100%;
  height: 100%;
}

.user-info {
  margin-left: 16px;
  color: #ffffff;
}

.user-name {
  font-size: 18px;
  font-weight: bold;
}

.user-vip-tag {
  font-size: 11px;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 2px 8px;
  border-radius: 10px;
  margin-top: 6px;
  display: inline-block;
}

.settings-list {
  padding: 0 16px;
}

.settings-item {
  padding: 16px 0;
  border-bottom: 1px solid #f2f3f5;
}

.settings-item:last-child {
  border-bottom: none;
}

.item-title {
  font-size: 15px;
  color: #323233;
}

.item-input {
  font-size: 14px;
  color: #1989fa;
  text-align: right;
  flex: 1;
  margin-left: 20px;
}

.help-card {
  padding: 16px;
}

.help-title {
  font-size: 15px;
  font-weight: bold;
  margin-bottom: 8px;
}

.help-desc {
  font-size: 13px;
  color: #646566;
  line-height: 1.6;
}