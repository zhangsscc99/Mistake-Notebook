/* pages/settings/settings.wxss */
.settings-page {
  min-height: 100vh;
  background: #eaf3ff;
  padding-bottom: 40px;
}

/* 用户头部 */
.user-header {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx 28rpx;
  background: linear-gradient(135deg, #2459ff 0%, #52b7ff 50%, #b6a6ff 100%);
  gap: 20rpx;
}

.avatar-container {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 3rpx solid rgba(255,255,255,0.5);
  flex-shrink: 0;
  background: rgba(255,255,255,0.2);
}

.user-avatar {
  width: 100%;
  height: 100%;
}

.user-info-block {
  flex: 1;
}

.user-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6rpx;
}

.user-name-placeholder {
  opacity: 0.8;
}

.user-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.75);
}

.user-stats {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stat-block {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1;
  margin-bottom: 4rpx;
}

.stat-lab {
  font-size: 20rpx;
  color: rgba(255,255,255,0.75);
}

.stat-divider {
  width: 1rpx;
  height: 36rpx;
  background: rgba(255,255,255,0.35);
}

/* 分组 */
.section-group {
  margin: 24rpx 24rpx 0;
}

.section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(11,22,51,0.5);
  padding: 0 4rpx 12rpx;
  letter-spacing: 1rpx;
}

.cell-list {
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(12px);
  border: 1rpx solid rgba(47,107,255,0.1);
  border-radius: 20rpx;
  overflow: hidden;
}

.cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid rgba(11,22,51,0.06);
}

.cell:last-child {
  border-bottom: none;
}

.cell-label {
  font-size: 28rpx;
  color: #0b1633;
  font-weight: 500;
}

.cell-label-danger {
  color: #ff4d4f;
}

.cell-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.cell-value {
  font-size: 26rpx;
  color: rgba(11,22,51,0.45);
}

.sync-text {
  color: #2459ff;
}

.cell-arrow {
  font-size: 32rpx;
  color: rgba(11,22,51,0.3);
  line-height: 1;
}

/* 云状态点 */
.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.status-ok {
  background: #52c41a;
  box-shadow: 0 0 6rpx rgba(82,196,26,0.5);
}
